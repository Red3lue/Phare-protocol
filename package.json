{
  "name": "phare-protocol",
  "version": "0.0.0",
  "private": true,
  "description": "Open, bonded registry of citizen sightings of sanctioned tankers — ETHPrague 2026",
  "packageManager": "pnpm@9.12.0",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "pnpm -r --if-present build",
    "dev:web": "pnpm --filter web dev",
    "test": "pnpm -r --if-present test",
    "lint": "pnpm -r --if-present lint",
    "contracts:build": "pnpm --filter contracts build",
    "contracts:test": "pnpm --filter contracts test",
    "contracts:deploy": "pnpm --filter contracts run deploy",
    "contracts:wrap": "pnpm --filter contracts run wrap"
  }
}
