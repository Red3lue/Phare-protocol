# Mirrors /.env.example for the verifier-agent skill. The deploy script
# (contracts/script/Deploy.s.sol) patches LIGHTHOUSE / REPORT_REGISTRY /
# SLASH_POOL into /agent/.env after each deploy.

SEPOLIA_RPC_URL=https://ethereum-sepolia-rpc.publicnode.com

# UMA OOv3 — Sepolia
UMA_OOV3=0xFd9e2642a170aDD10F53Ee14a93FcF2F31924944

# Bond currency — WETH on Sepolia
BOND_CURRENCY=0x7b79995e5f793A07Bc00c21412e50Ecae098E7f9

# ENS infra
ENS_NAMEWRAPPER=0x0635513f179D50A207757E05759CbD106d7dFcE8
ENS_PUBLIC_RESOLVER=0x8FADE66B79cC9f707aB26799354482EB93a5B7dD
VESSEL_PARENT_NODE=vessel.phare.eth
VERIFIER_PARENT_NODE=verifier.phare.eth

# Phare deployed (patched by Deploy.s.sol)
REPORT_REGISTRY=0x6696b738687926255A48b51A86C6d10F35FEc84C
SLASH_POOL=0xDE7F33d67F077c066697d67A23624275507899DB
LIGHTHOUSE=0x69d4AFCf2d68949B8550B2b023FC22C81e1EE1C4

# Swarm gateway used to fetch metadata from UMA ancillaryData URLs
# (real bee-js + BMT verification arrives with the swarm tool, deferred)
SWARM_GATEWAY=https://api.gateway.ethswarm.org/access/

# Bee API endpoint used by tools/lib/swarm.mjs for /bytes/<hash> reads
# and uploadData writes.
SWARM_BEE_URL=https://bzz.limo

# Faucets (printed to user during needs-funding phase)
SEPOLIA_ETH_FAUCET=https://sepoliafaucet.com
SEPOLIA_WETH_WRAP=https://app.uniswap.org/swap?chain=sepolia
