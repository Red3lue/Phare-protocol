# Mirrors /.env.example (root). Vars consumed by the browser are prefixed
# NEXT_PUBLIC_* per Next.js convention. Server-only secrets (private keys,
# API keys) live here too for parity with the root file but are NOT exposed
# to client bundles unless prefixed.

# Sepolia (chainId 11155111) — canonical testnet per DESIGN_DOCUMENT §20
SEPOLIA_RPC_URL=https://ethereum-sepolia-rpc.publicnode.com
# Browser-exposed RPC URL (no API key — must allow CORS). publicnode does.
NEXT_PUBLIC_SEPOLIA_RPC_URL=https://ethereum-sepolia-rpc.publicnode.com
DEPLOYER_PRIVATE_KEY=
ETHERSCAN_API_KEY=

# UMA OOv3 — Sepolia (UMA networks/11155111.json)
NEXT_PUBLIC_UMA_OOV3=0xFd9e2642a170aDD10F53Ee14a93FcF2F31924944

# Bond currency on Sepolia — WETH (UMA-whitelisted, min bond 0.002 WETH).
NEXT_PUBLIC_BOND_CURRENCY=0x7b79995e5f793A07Bc00c21412e50Ecae098E7f9

# Deploy overrides
TREASURY=
ORBITAL_ATTESTOR=
PROTOCOL_BOND=
LIVENESS=
SWARM_GATEWAY=

# ENS — wrapped parents and resolvers
ENS_NAMEWRAPPER=0x0635513f179D50A207757E05759CbD106d7dFcE8
ENS_PUBLIC_RESOLVER=0x8FADE66B79cC9f707aB26799354482EB93a5B7dD
VESSEL_PARENT_NODE=vessel.phare.eth
VERIFIER_PARENT_NODE=verifier.phare.eth

# Deployed addresses (filled after deploy)
NEXT_PUBLIC_REPORT_REGISTRY=0x6696b738687926255A48b51A86C6d10F35FEc84C
NEXT_PUBLIC_SLASH_POOL=0xDE7F33d67F077c066697d67A23624275507899DB
NEXT_PUBLIC_LIGHTHOUSE=0x69d4AFCf2d68949B8550B2b023FC22C81e1EE1C4

# Lower-bound block for VesselNamed / VerifierEnrolled event scans.
NEXT_PUBLIC_DEPLOY_BLOCK=10800000

# Swarm (Bee node or hosted gateway, e.g. https://bzz.limo)
NEXT_PUBLIC_SWARM_BEE_URL=https://bzz.limo

# OpenSanctions
OPENSANCTIONS_API_KEY=

# Orbitport (SpaceComputer)
ORBITPORT_CLIENT_ID=
ORBITPORT_CLIENT_SECRET=
ORBITPORT_KMS_ETH_KEY_ID=
